# IBKR connection (configured in config/settings.yaml — no API keys needed)
# IB Gateway or TWS must be running locally on the configured host/port

# Data Sources
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Database
POSTGRES_PASSWORD=dev_password

# Settings passed to the app (SA_ prefix for pydantic-settings)
SA_ALPHA_VANTAGE_API_KEY=${ALPHA_VANTAGE_API_KEY}
SA_DATABASE__URL=postgresql+asyncpg://trader:${POSTGRES_PASSWORD}@localhost:5432/stock_analysis
SA_REDIS__URL=redis://localhost:6379/0

# Monitoring
GRAFANA_PASSWORD=admin

# Notifications (optional)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM (Phase 2+)
ANTHROPIC_API_KEY=
