# IBKR connection (configured in config/settings.yaml — no API keys needed)
# IB Gateway or TWS must be running locally on the configured host/port
# No API key — connects via a local socket (config in config/settings.yaml)

# Database
POSTGRES_PASSWORD=dev_password

# Monitoring
GRAFANA_PASSWORD=admin

# Notifications (optional)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM (Phase 2+)
ANTHROPIC_API_KEY=

#####################################################################
# Settings passed to the app (SA_ prefix for pydantic-settings)
#####################################################################

# AlphaVantage API Key — for historical price bars and fundamentals (backfill + scheduled ingestion)  
# Free tier: 25 requests/day (very limited), paid "premium" starts at ~$50/mo for 75 req/min                              
# Get one at: https://www.alphavantage.co/support/#api-key  
SA_ALPHA_VANTAGE_API_KEY=YOUR_KEY_HERE
SA_DATABASE__URL=postgresql+asyncpg://trader:${POSTGRES_PASSWORD}@localhost:5432/stock_analysis
SA_REDIS__URL=redis://localhost:6379/0


